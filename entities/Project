{
  "name": "Project",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del proyecto"
    },
    "description": {
      "type": "string",
      "description": "Descripci\u00f3n del proyecto"
    },
    "client": {
      "type": "string",
      "description": "Cliente o propietario"
    },
    "location": {
      "type": "string",
      "description": "Ubicaci\u00f3n de la obra"
    },
    "engineer": {
      "type": "string",
